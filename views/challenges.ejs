<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>챌린지 - AXIO</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .progress-bar-wrap {
      background: var(--border);
      border-radius: 99px;
      height: 8px;
      overflow: hidden;
      margin: 8px 0 4px;
    }
    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 99px;
      transition: width .4s ease;
    }
    .challenge-card.solved {
      border-color: rgba(0,200,150,.4);
      background: rgba(0,200,150,.04);
    }
    .solved-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: rgba(0,200,150,.15);
      color: var(--accent);
      border: 1px solid rgba(0,200,150,.3);
      border-radius: 4px;
      padding: 2px 8px;
      font-size: 11px;
      font-weight: 600;
    }
    .flag-form {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }
    .flag-form input {
      flex: 1;
      font-family: 'Consolas', monospace;
      font-size: 13px;
    }
    .result-ok  { color: var(--accent);  font-size: 13px; margin-top: 8px; }
    .result-err { color: var(--red);     font-size: 13px; margin-top: 8px; }
    .cat-header {
      font-size: 13px;
      color: var(--accent);
      margin: 24px 0 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
      font-weight: 600;
    }
  </style>
</head>
<body>
<%- include('partials/nav') %>
<div class="container">

  <!-- 헤더 & 진행률 -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;gap:24px;flex-wrap:wrap">
    <div>
      <div class="page-title" style="margin-bottom:4px">취약점 챌린지</div>
      <div style="color:var(--text2);font-size:13px">OWASP Top 10 기반 시나리오 | 총 <%= challenges.length %>개</div>
    </div>
    <% if (user) { %>
    <div class="card" style="min-width:240px;padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
        <span style="font-size:12px;color:var(--text2)">내 진행률</span>
        <span style="font-weight:700;color:var(--accent)"><%= solvedIds.length %> / <%= challenges.length %></span>
      </div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-fill" style="width:<%= Math.round(solvedIds.length/challenges.length*100) %>%"></div>
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:6px">
        <span style="font-size:11px;color:var(--text2)"><%= Math.round(solvedIds.length/challenges.length*100) %>% 완료</span>
        <span style="font-size:13px;font-weight:700;color:var(--accent)">🏅 <%= myScore.toLocaleString() %> <span style="color:var(--text2);font-weight:400;font-size:11px">/ <%= maxScore.toLocaleString() %>pt</span></span>
      </div>
    </div>
    <% } %>
  </div>

  <!-- FLAG 제출 결과 메시지 -->
  <% if (submitResult) { %>
  <div class="alert <%= submitResult.success ? 'alert-success' : 'alert-error' %>" style="margin-bottom:20px">
    <% if (submitResult.success && !submitResult.alreadySolved) { %>
    🎉 <%= submitResult.message %>
    <% } else if (submitResult.alreadySolved) { %>
    ✅ <%= submitResult.message %>
    <% } else { %>
    ❌ <%= submitResult.message %>
    <% } %>
    <% if (submitResult.success && !submitResult.alreadySolved) { %>
    &nbsp;· 현재 점수: <strong><%= myScore.toLocaleString() %>pt</strong>
    <% } %>
  </div>
  <% } %>

  <div class="alert alert-warning" style="margin-bottom:20px">
    ⚠️ 교육 목적 전용입니다. 실제 서비스에 동일 기법을 사용하는 것은 불법입니다.
    <% if (!user) { %> | <a href="/login">로그인</a>하면 진행률을 저장할 수 있습니다.<% } %>
  </div>

  <!-- 랭킹 링크 -->
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
    <div></div>
    <a href="/challenges/ranking" class="btn btn-secondary btn-sm">🏆 랭킹 보기</a>
  </div>

  <%
    const categories = [...new Set(challenges.map(c => c.category))];
  %>

  <!-- ③ 카테고리별 진행도 -->
  <% if (user) { %>
  <div class="card" style="margin-bottom:24px">
    <div class="card-title">카테고리별 진행 현황</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-top:8px">
      <% categories.forEach(cat => {
           const catChallenges = challenges.filter(c => c.category === cat);
           const catSolved = catChallenges.filter(c => solvedIds.includes(c.id)).length;
           const catTotal = catChallenges.length;
           const catPct = Math.round(catSolved / catTotal * 100);
           const catScore = catChallenges.filter(c => solvedIds.includes(c.id)).reduce((s,c) => s + (SCORE[c.difficulty]||100), 0);
           const catMaxScore = catChallenges.reduce((s,c) => s + (SCORE[c.difficulty]||100), 0);
      %>
      <div style="background:var(--bg);border-radius:8px;padding:10px;border:1px solid var(--border)">
        <div style="font-size:11px;color:var(--text2);margin-bottom:4px"><%= cat.split(' - ')[0] %></div>
        <div style="font-size:12px;font-weight:600;margin-bottom:6px;line-height:1.3"><%= cat.includes(' - ') ? cat.split(' - ')[1] : cat %></div>
        <div style="background:var(--border);border-radius:99px;height:5px;overflow:hidden;margin-bottom:4px">
          <div style="height:100%;width:<%= catPct %>%;background:<%= catPct===100 ? 'var(--accent)' : 'var(--accent2)' %>;border-radius:99px;transition:width .4s"></div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:11px">
          <span style="color:<%= catPct===100 ? 'var(--accent)' : 'var(--text2)' %>"><%= catSolved %>/<%= catTotal %> <%= catPct===100 ? '✔ 완료' : '' %></span>
          <span style="color:var(--accent);font-weight:600"><%= catScore %>/<%= catMaxScore %>pt</span>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- 챌린지 목록 -->
  <% categories.forEach(cat => { %>
    <div class="cat-header"><%= cat %></div>
    <% challenges.filter(c => c.category === cat).forEach(ch => {
         const isSolved = solvedIds.includes(ch.id);
    %>
    <div class="challenge-card <%= isSolved ? 'solved' : '' %>">
      <div class="challenge-header">
        <span class="difficulty <%= ch.difficulty %>"><%= ch.difficulty.toUpperCase() %></span>
        <strong style="flex:1"><%= ch.title %></strong>
        <span style="color:var(--text2);font-size:11px;margin-right:8px"><%= ch.id %></span>
        <span style="font-size:12px;font-weight:700;color:<%= ch.difficulty==='hard'?'#f59e0b':ch.difficulty==='medium'?'var(--accent2)':'var(--text2)' %>;margin-right:8px"><%= SCORE[ch.difficulty] %>pt</span>
        <% if (isSolved) { %>
        <span class="solved-badge">✔ SOLVED</span>
        <% } %>
      </div>

      <p style="color:var(--text2);font-size:13px;margin-bottom:8px"><%= ch.description %></p>
      <div style="font-size:12px;color:var(--text2);margin-bottom:10px">
        대상: <code><%= ch.target %></code>
      </div>

      <!-- 힌트 (단계별 공개, 힌트당 -10pt) -->
      <% if (!isSolved) { %>
      <div class="hint-section" id="hint-<%= ch.id %>">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
          <span style="font-size:12px;color:var(--text2)">💡 힌트</span>
          <span style="font-size:11px;color:var(--red)">힌트 1개당 -10pt</span>
          <div style="flex:1"></div>
          <% if (user) { %>
          <button class="btn btn-secondary btn-sm" style="font-size:11px" onclick="revealHint('<%= ch.id %>', 0, <%= ch.hints.length %>)">
            힌트 1 보기
          </button>
          <% } %>
        </div>
        <div id="hints-<%= ch.id %>" style="display:none"></div>
      </div>
      <% } else { %>
      <details style="margin-top:8px">
        <summary style="cursor:pointer;font-size:12px;color:var(--text2);user-select:none">풀이 힌트 보기</summary>
        <ol style="margin:8px 0 0 16px;color:var(--text2);font-size:12px;line-height:2">
          <% ch.hints.forEach(h => { %><li><%= h %></li><% }) %>
        </ol>
      </details>
      <% } %>

      <details style="margin-top:6px">
        <summary style="cursor:pointer;font-size:11px;color:var(--red);user-select:none">🚩 FLAG 직접 보기 (스포일러 주의)</summary>
        <code style="display:block;margin-top:6px;color:var(--accent);padding:6px;font-size:12px"><%= ch.flag %></code>
      </details>

      <!-- FLAG 제출 폼 -->
      <% if (user) { %>
      <% if (isSolved) { %>
      <div style="margin-top:10px;font-size:13px;color:var(--accent)">✔ 이 챌린지를 완료했습니다.</div>
      <% } else { %>
      <form class="flag-form" method="POST" action="/challenges/submit">
        <input type="hidden" name="challenge_id" value="<%= ch.id %>">
        <input type="text" name="flag" placeholder="AXIO{...} 형식으로 FLAG 입력" autocomplete="off">
        <button type="submit" class="btn btn-primary btn-sm">제출</button>
      </form>
      <% } %>
      <% } else { %>
      <div style="margin-top:10px;font-size:12px;color:var(--text2)">
        FLAG를 제출하려면 <a href="/login">로그인</a>하세요.
      </div>
      <% } %>
    </div>
    <% }) %>
  <% }) %>

  <!-- 수료증 링크 (로그인 시) -->
  <% if (user) { %>
  <div class="card" style="margin-top:32px;text-align:center;padding:24px">
    <div style="font-size:16px;font-weight:700;margin-bottom:8px">
      <% if (solvedIds.length === challenges.length) { %>
      🎉 모든 챌린지를 완료했습니다!
      <% } else { %>
      📜 수료증 미리보기
      <% } %>
    </div>
    <div style="color:var(--text2);font-size:13px;margin-bottom:16px">
      현재 <%= solvedIds.length %>/<%= challenges.length %>개 완료 · <%= myScore %>pt
      <% if (solvedIds.length === challenges.length) { %>
       · <strong style="color:var(--accent)">수료 조건 달성!</strong>
      <% } %>
    </div>
    <a href="/challenges/certificate" class="btn btn-primary">🏆 수료증 보기</a>
  </div>
  <% } %>
</div>

<script>
const hintState = {}; // { [challengeId]: { revealed: [0,1,...], nextIndex: N } }

async function revealHint(challengeId, index, total) {
  if (!hintState[challengeId]) hintState[challengeId] = { revealed: [], nextIndex: 0 };
  const state = hintState[challengeId];
  const nextIdx = state.nextIndex;

  const res = await fetch('/challenges/hint', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `challenge_id=${challengeId}&hint_index=${nextIdx}`
  });
  const data = await res.json();
  if (data.error) return;

  const container = document.getElementById('hints-' + challengeId);
  container.style.display = 'block';

  // 힌트 항목 추가
  const item = document.createElement('div');
  item.style.cssText = 'padding:8px 12px;background:var(--bg);border-radius:6px;font-size:13px;color:var(--text2);margin-bottom:6px;border-left:3px solid var(--accent2)';
  item.innerHTML = `<span style="color:var(--accent2);font-weight:600">힌트 ${nextIdx + 1}</span>${data.already_seen ? '' : ' <span style="color:var(--red);font-size:11px">-10pt</span>'}: ${data.hint}`;
  container.appendChild(item);

  state.revealed.push(nextIdx);
  state.nextIndex = nextIdx + 1;

  // 다음 힌트 버튼 업데이트
  const section = document.getElementById('hint-' + challengeId);
  const btn = section.querySelector('button');
  if (state.nextIndex < total) {
    btn.textContent = `힌트 ${state.nextIndex + 1} 보기`;
    btn.onclick = () => revealHint(challengeId, state.nextIndex, total);
  } else {
    btn.textContent = '힌트 모두 봄';
    btn.disabled = true;
    btn.style.opacity = '0.5';
  }
}
</script>
</body>
</html>
