<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>로그인 - PRAVANG</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">PRAVANG</div>
    <div class="auth-sub">훈련용 거래소에 로그인하세요</div>

    <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (typeof debugQuery !== 'undefined' && debugQuery) { %>
    <div class="alert alert-warning">
      <strong>🐛 디버그 쿼리 (A05 - 정보 노출):</strong><br>
      <code><%= debugQuery %></code>
    </div>
    <% if (debugQuery.includes("'--") || debugQuery.includes("'/*")) { %>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        showAttackBanner('A03', 'A03 - SQL Injection 로그인 우회', "SQL 주석(!--)을 이용해 WHERE 절을 무력화했습니다. 비밀번호 검증이 완전히 생략됩니다.");
      });
    </script>
    <% } %>
    <% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label>아이디</label>
        <input type="text" name="username" placeholder="아이디를 입력하세요" autocomplete="off">
      </div>
      <div class="form-group">
        <label>비밀번호</label>
        <input type="password" name="password" placeholder="비밀번호를 입력하세요">
      </div>
      <button type="submit" class="btn btn-primary btn-block">로그인</button>
    </form>

    <div class="divider"></div>
    <div style="text-align:center;color:var(--text2);font-size:13px">
      계정이 없으신가요? <a href="/register">회원가입</a>
    </div>

    <% if (typeof attemptCount !== 'undefined' && attemptCount > 0) { %>
    <div class="alert alert-error" style="margin-top:12px;font-size:12px">
      ⚠️ 최근 10분간 <strong><%= attemptCount %>회</strong> 로그인 실패.
      계정 잠금 없음 — 브루트포스 가능 (A07).<br>
      <a href="/system/login-log" style="color:var(--red)">로그인 시도 로그 보기 →</a>
    </div>
    <% } %>

    <div class="alert alert-warning" style="margin-top:16px;font-size:12px">
      <strong>힌트:</strong> 이 로그인 폼은 SQL Injection에 취약합니다.<br>
      username: <code>admin'--</code> 로 시도해보세요.
    </div>
  </div>
</div>
</body>
</html>
