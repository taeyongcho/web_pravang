<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>랭킹 - PRAVANG</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>
<div class="container" style="max-width:700px">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
    <div class="page-title" style="margin:0">🏆 챌린지 랭킹</div>
    <a href="/challenges" class="btn btn-secondary btn-sm">← 챌린지 목록</a>
  </div>

  <div class="card">
    <% if (ranking.length === 0) { %>
    <p style="text-align:center;color:var(--text2);padding:32px">아직 풀린 챌린지가 없습니다.</p>
    <% } else { %>
    <table>
      <tr>
        <th style="width:50px">순위</th>
        <th>닉네임</th>
        <th>풀이 수</th>
        <th>진행률</th>
        <th>마지막 풀이</th>
      </tr>
      <% ranking.forEach((r, i) => { %>
      <tr>
        <td>
          <% if (i === 0) { %><span style="font-size:18px">🥇</span>
          <% } else if (i === 1) { %><span style="font-size:18px">🥈</span>
          <% } else if (i === 2) { %><span style="font-size:18px">🥉</span>
          <% } else { %><span style="color:var(--text2)">#<%= i+1 %></span>
          <% } %>
        </td>
        <td>
          <strong><%= r.username %></strong>
          <% if (user && user.username === r.username) { %>
          <span class="badge" style="margin-left:6px">나</span>
          <% } %>
        </td>
        <td><strong style="color:var(--accent)"><%= r.solved_count %></strong> / <%= total %></td>
        <td>
          <div style="display:flex;align-items:center;gap:8px">
            <div style="background:var(--border);border-radius:99px;height:6px;width:100px;overflow:hidden">
              <div style="height:100%;background:var(--accent);width:<%= Math.round(r.solved_count/total*100) %>%;border-radius:99px"></div>
            </div>
            <span style="font-size:12px;color:var(--text2)"><%= Math.round(r.solved_count/total*100) %>%</span>
          </div>
        </td>
        <td style="color:var(--text2);font-size:12px"><%= r.last_solved ? r.last_solved.slice(0,16) : '-' %></td>
      </tr>
      <% }) %>
    </table>
    <% } %>
  </div>
</div>
</body>
</html>
